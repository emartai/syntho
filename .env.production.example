# ══════════════════════════════════════════════════════════════════════════════
# Syntho — Production Environment Variables
# Copy this file. Fill in real values. NEVER commit the filled-in version.
# ══════════════════════════════════════════════════════════════════════════════

# ── SUPABASE ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=              # Supabase project URL (Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # Supabase anon/public key
SUPABASE_SERVICE_ROLE_KEY=             # Supabase service role key (backend only — never NEXT_PUBLIC_)

# ── BACKEND API (Render) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=                   # Your Render backend URL e.g. https://syntho-backend.onrender.com
SUPABASE_URL=                          # Same as NEXT_PUBLIC_SUPABASE_URL, for FastAPI
SUPABASE_SERVICE_KEY=                  # Same service role key, for FastAPI
SUPABASE_JWT_SECRET=                   # Must match Supabase JWT secret (Settings → API → JWT Settings)
FRONTEND_URL=                          # Your Vercel production URL e.g. https://syntho.vercel.app
ALLOWED_ORIGINS=                       # Comma-separated: https://syntho.vercel.app

# ── MODAL ML ──────────────────────────────────────────────────────────────────
MODAL_API_URL=                         # Your deployed Modal endpoint URL
MODAL_API_SECRET=                      # Secret shared between backend and Modal

# ── FRONTEND FEATURE FLAGS (all false for MVP) ────────────────────────────────
NEXT_PUBLIC_FLAG_MARKETPLACE=false
NEXT_PUBLIC_FLAG_API_KEYS=false
NEXT_PUBLIC_FLAG_GROQ_AI=false
NEXT_PUBLIC_FLAG_ADMIN_PANEL=false
NEXT_PUBLIC_FLAG_NOTIFICATIONS=false
NEXT_PUBLIC_FLAG_TEAM_ACCOUNTS=false

# ── OPTIONAL (v2 features — leave blank to disable gracefully) ────────────────
GROQ_API_KEY=                          # Groq API key — only needed for v2 AI features
FLUTTERWAVE_PUBLIC_KEY=                # Flutterwave — only needed for v2 marketplace
FLUTTERWAVE_SECRET_KEY=                # Flutterwave — only needed for v2 marketplace
FLUTTERWAVE_WEBHOOK_SECRET=            # Flutterwave — only needed for v2 marketplace
REDIS_URL=                             # Redis URL — rate limiting falls back to in-memory if unset
