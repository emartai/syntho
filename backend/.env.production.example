# ============================
# Syntho Backend (Production)
# ============================
# Copy this file to `.env` in production and set real values.

# Supabase project URL (https://<project-ref>.supabase.co)
SUPABASE_URL=
# Supabase service-role key (server-side only, never expose to frontend)
SUPABASE_SERVICE_KEY=
# Supabase JWT secret used to verify Auth tokens
SUPABASE_JWT_SECRET=

# Modal endpoint URL from `modal deploy modal_ml/main.py`
MODAL_API_URL=
# Shared secret that backend sends to Modal and Modal validates
MODAL_API_SECRET=

# Primary frontend URL (production Vercel custom domain)
FRONTEND_URL=https://app.syntho.ai
# Additional comma-separated allowed origins (e.g., preview, staging)
ALLOWED_ORIGINS=https://app.syntho.ai,https://syntho.vercel.app
# Regex for preview origins (set to Vercel preview by default)
ALLOWED_ORIGIN_REGEX=^https://.*\\.vercel\\.app$

# Freemium quotas
FREE_JOBS_QUOTA=10
FREE_ROW_CAP=10000
PRO_ROW_CAP=500000
GROWTH_ROW_CAP=5000000

# Billing provider
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_HASH=

# Optional integrations
GROQ_API_KEY=
REDIS_URL=
