# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend API (Render)
NEXT_PUBLIC_API_URL=https://your-render-app.onrender.com

# Flutterwave (public key only — secret key stays on backend)
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_LIVE-your_flutterwave_public_key

# Sample dataset path in Supabase Storage (public bucket)
NEXT_PUBLIC_SAMPLE_DATASET_PATH=datasets/sample/nigerian_retail_sample.csv
