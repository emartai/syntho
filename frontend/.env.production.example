# =============================
# Syntho Frontend (Production)
# =============================
# Copy to `.env.production` for Vercel environment variables.

# Public Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=
# Public Supabase anon key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public backend API URL (Render production URL)
NEXT_PUBLIC_API_URL=https://syntho-backend.onrender.com

# Path in Supabase Storage used by onboarding "Load Sample Dataset"
# Upload `samples/nigerian_retail_sample.csv` to: datasets/sample/nigerian_retail_sample.csv
NEXT_PUBLIC_SAMPLE_DATASET_PATH=datasets/sample/nigerian_retail_sample.csv

# Optional feature flags (true/false)
NEXT_PUBLIC_FLAG_MARKETPLACE=false
NEXT_PUBLIC_FLAG_AI_ADVISOR=false
NEXT_PUBLIC_FLAG_TEAMS=false
